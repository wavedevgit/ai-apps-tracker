{"information_for_contributors":["ERB (Embedded Ruby) grammar: HTML base with embedded Ruby via <% %> delimiters.","Includes text.html.basic for HTML structure and source.ruby for Ruby code."],"name":"HTML (ERB)","scopeName":"text.html.erb","patterns":[{"include":"#erbComment"},{"include":"#erbOutputTag"},{"include":"#erbTag"},{"include":"text.html.derivative"}],"repository":{"erbComment":{"begin":"<%#","beginCaptures":{"0":{"name":"punctuation.definition.comment.begin.erb"}},"end":"-?%>","endCaptures":{"0":{"name":"punctuation.definition.comment.end.erb"}},"name":"comment.block.erb"},"erbOutputTag":{"begin":"<%={1,2}","beginCaptures":{"0":{"name":"punctuation.section.embedded.begin.erb"}},"end":"-?%>","endCaptures":{"0":{"name":"punctuation.section.embedded.end.erb"}},"name":"meta.embedded.line.erb","contentName":"source.ruby","patterns":[{"include":"source.ruby"}]},"erbTag":{"begin":"<%-?","beginCaptures":{"0":{"name":"punctuation.section.embedded.begin.erb"}},"end":"-?%>","endCaptures":{"0":{"name":"punctuation.section.embedded.end.erb"}},"name":"meta.embedded.block.erb","contentName":"source.ruby","patterns":[{"include":"source.ruby"}]}}}